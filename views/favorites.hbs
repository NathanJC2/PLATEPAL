<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PlatePal - Favorites</title>
<link rel="stylesheet" href="/css/global.css">
<link rel="stylesheet" href="/css/favorites.css">
</head>

<body>

<nav>
    <h1>PlatePal</h1>
    <div>
        <a href="/">Home</a>
        <a href="/establishments">Establishments</a>
        <a href="/favorites">Favorites</a>
        <a href="/search-users">Find Users</a>
        <a href="/about">About</a>
        <a href="/login" id="navLogin">Login</a>
        <a href="/register" id="navRegister">Register</a>
        <a href="#" id="navMyEstablishment" style="display:none;">My Establishment</a>
        <a href="/profile" id="navProfile" style="display:none;">My Profile</a>
        <a href="#" onclick="logout()" id="navLogout" style="display:none;">Logout</a>
    </div>
</nav>

<div class="header">
    <h2>My Favorite Establishments</h2>
    <p>Restaurants you've added to your favorites</p>
</div>

<div class="section">
    <div class="cards" id="favoritesContainer"></div>
    <div id="noFavoritesMessage" class="no-favorites" style="display: none;">
        <h3>No Favorites Yet</h3>
        <p>You haven't added any restaurants to your favorites.</p>
        <a href="/establishments">Browse Establishments</a>
    </div>

    <div id="loginRequiredMessage" class="no-favorites" style="display: none;">
        <h3>Login Required</h3>
        <p>You need to be logged in to view and add favorites.</p>
        <a href="/login">Login</a>
        <span> or </span>
        <a href="/register">Register</a>
    </div>
</div>

<footer>
    © 2026 PlatePal | Restaurant Review Platform
</footer>

<script src="/js/global.js"></script>
<script src="/js/favorites.js"></script>

</body>
</html>


