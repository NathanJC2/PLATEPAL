<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PlatePal - Register</title>
<link rel="stylesheet" href="/css/global.css">
<link rel="stylesheet" href="/css/register.css">
</head>

<body>

<nav>
    <h1>PlatePal</h1>
    <div>
        <a href="/">Home</a>
        <a href="/establishments">Establishments</a>
        <a href="/favorites">Favorites</a>
        <a href="/about">About</a>
        <a href="/login">Login</a>
        <a href="/register">Register</a>
    </div>
</nav>

<div class="container">
    <div class="register-box">
        <h2>Create Account</h2>

        <input type="text" id="username" placeholder="Username" required>
        <input type="password" id="password" placeholder="Password" required>

        <label style="display:block; margin-top:15px; margin-bottom:8px; font-weight:bold; color:#333;">Account Type:</label>
        <select id="accountType" style="width:100%; padding:10px; margin-bottom:15px; border:1px solid #ddd; border-radius:4px;" onchange="toggleEstablishmentSelect()">
            <option value="user">Regular User</option>
            <option value="owner">Establishment Owner</option>
        </select>

        <div id="ownerCodeContainer" style="display:none; margin-bottom:15px;">
            <label style="display:block; margin-bottom:8px; font-weight:bold; color:#333;">Owner Registration Code:</label>
            <input id="ownerCode" style="width:100%; padding:10px; border:1px solid #ddd; border-radius:4px;" placeholder="Enter code provided by admin" />
            <p style="font-size:12px; color:#666; margin-top:8px;">Owner accounts require a registration code. Contact an admin to get one.</p>
        </div>

        <div id="establishmentSelectContainer" style="display:none; margin-bottom:15px;">
            <label style="display:block; margin-bottom:8px; font-weight:bold; color:#333;">Your Establishment:</label>
            <select id="establishmentSelect" disabled style="width:100%; padding:10px; border:1px solid #ddd; border-radius:4px;">
                <option value="" disabled selected>Loading establishments...</option>
            </select>
        </div>

        <div class="avatar-preview">
            <div style="display:flex;flex-direction:column;align-items:center;">
                <div class="avatar-circle" id="avatarCircle">
                    <img id="avatarImage" style="display:none;" />
                    <svg class="avatar-placeholder" id="avatarPlaceholder" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="12" fill="#ccc"/><path d="M12 13c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v1h16v-1c0-2.66-5.33-4-8-4z" fill="#fff"/></svg>
                </div>
                <button type="button" id="avatarAddBtn" style="width:22px;height:22px;border-radius:50%;background:#8B0000;color:#fff;font-size:16px;border:none;display:flex;align-items:center;justify-content:center;cursor:pointer;margin-top:6px;">+</button>
            </div>
            <input type="file" id="avatarUpload" class="avatar-upload-input" accept="image/*">
        </div>

        <textarea id="description" placeholder="Short description about you..."></textarea>

        <button onclick="registerUser()">Register</button>

        <div class="login-link">
            Already have an account?
            <a href="/login">Login here</a>
        </div>
    </div>
</div>

<footer>
    © 2026 PlatePal | Restaurant Review Platform
</footer>

<script src="/js/global.js"></script>
<script src="/js/register.js"></script>


</body>
</html>


