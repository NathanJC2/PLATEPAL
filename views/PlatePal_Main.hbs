<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PlatePal - Home</title>
<link rel="stylesheet" href="/css/global.css">
<link rel="stylesheet" href="/css/PlatePal_Main.css">
</head>

<body>

<nav>
    <h1>PlatePal</h1>
    <div>
        <a href="/">Home</a>
        <a href="/establishments">Establishments</a>
        <a href="/favorites">Favorites</a>
        <a href="/search-users">Find Users</a>
        <a href="/about">About</a>
        <a href="/login" id="navLogin">Login</a>
        <a href="/register" id="navRegister">Register</a>
        <a href="#" id="navMyEstablishment" style="display:none;">My Establishment</a>
        <a href="/profile" id="navProfile" style="display:none;">My Profile</a>
        <a href="#" onclick="logout()" id="navLogout" style="display:none;">Logout</a>
    </div>
</nav>

<div class="hero">
    <h2>Discover Your Next Favorite Restaurant</h2>
    <p>Browse reviews. Share experiences. Make smarter dining choices.</p>

    <div class="search-section">
        <input type="text" id="searchInput" placeholder="Search restaurants...">
        <select id="ratingFilter">
            <option value="all">All Ratings</option>
            <option value="4">4★ & Above</option>
            <option value="3">3★ & Above</option>
            <option value="2">2★ & Above</option>
            <option value="1">1★ & Above</option>
        </select>
        <button onclick="filterRestaurants()">Search</button>
    </div>
</div>

<div class="section">
    <h2>Most Reviewed Establishments</h2>
    <div class="cards" id="mostReviewed"></div>
</div>

<div class="section">
    <h2 id="nearbyHeading">Near You</h2>
    <p id="nearbySubtitle">Allow location access to get restaurant suggestions close to you.</p>
    <div class="cards" id="nearby"></div>
</div>

<div class="section">
    <h2>Recently Viewed</h2>
    <div class="cards" id="recent"></div>
</div>

<footer>
    © 2026 PlatePal | Restaurant Review Platform
</footer>

<script src="/js/global.js"></script>
<script src="/js/PlatePal_Main.js"></script>

</body>
</html>




