<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Create Review - PlatePal</title>
<link rel="stylesheet" href="/css/global.css">
<link rel="stylesheet" href="/css/create-review.css">
</head>

<body>

<nav>
    <h1>PlatePal</h1>
    <div>
        <a href="/">Home</a>
        <a href="/establishments">Establishments</a>
        <a href="/favorites">Favorites</a>
        <a href="/search-users">Find Users</a>
        <a href="/about">About</a>
        <a href="/login" id="navLogin">Login</a>
        <a href="/register" id="navRegister">Register</a>
        <a href="#" id="navMyEstablishment" style="display:none;">My Establishment</a>
        <a href="/profile" id="navProfile" style="display:none;">My Profile</a>
        <a href="#" onclick="logout()" id="navLogout" style="display:none;">Logout</a>
    </div>
</nav>

<div class="container">
    <h1>Create a Review</h1>
    <div class="test-buttons">
        <button onclick="openReviewModal()">Create Review</button>
    </div>

    <div class="instructions">
        <h3>How it works</h3>
        <ul>
            <li>Choose a rating and write your review.</li>
            <li>Add an optional image or video.</li>
            <li>Submit to save your review in your profile.</li>
        </ul>
    </div>
</div>

<div id="reviewModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 id="modalTitle">Create Review</h2>
            <button class="close-modal" type="button" onclick="closeReviewModal()">×</button>
        </div>

        <div id="lastModifiedIndicator" class="last-modified" style="display:none;"></div>

        <form id="reviewForm" onsubmit="submitReview(event)">
            <input type="hidden" id="ratingInput" value="0">

            <div class="form-group">
                <label for="reviewTitle">Review Title</label>
                <input type="text" id="reviewTitle" placeholder="Summarize your experience..." required>
            </div>

            <div class="form-group">
                <label for="reviewBody">Review</label>
                <textarea id="reviewBody" placeholder="Share your experience in detail..." required></textarea>
            </div>

            <div class="form-group">
                <label>Rating</label>
                <div class="star-rating-input">
                    <span class="star-input" onclick="setRating(1)">★</span>
                    <span class="star-input" onclick="setRating(2)">★</span>
                    <span class="star-input" onclick="setRating(3)">★</span>
                    <span class="star-input" onclick="setRating(4)">★</span>
                    <span class="star-input" onclick="setRating(5)">★</span>
                </div>
            </div>

            <div class="upload-section">
                <div class="upload-group">
                    <label for="imageUpload">Image</label>
                    <input type="file" id="imageUpload" accept="image/*">
                    <div id="imagePreview" class="upload-preview"></div>
                </div>
                <div class="upload-group">
                    <label for="videoUpload">Video</label>
                    <input type="file" id="videoUpload" accept="video/*">
                    <div id="videoPreview" class="upload-preview"></div>
                </div>
            </div>

            <div class="modal-actions">
                <button type="submit" class="btn btn-primary">Submit Review</button>
                <button type="button" class="btn btn-secondary" onclick="closeReviewModal()">Cancel</button>
            </div>
        </form>
    </div>
</div>

<footer>
    © 2026 PlatePal | Restaurant Review Platform
</footer>

<script src="/js/global.js"></script>
<script src="/js/create-review.js"></script>

</body>
</html>

